   "source": [
    "import numpy as np\n",
    "\n",
    "rad_60 = 60/180*np.pi\n",
    "rad_28 = 28/180*np.pi\n",
    "dotprod = np.cos(rad_60)*np.cos(rad_28)**2+np.sin(rad_28)**2\n",
    "\n",
    "angle = np.acos(dotprod)*180/np.pi\n",
    "print(angle)"
   ]
  }
